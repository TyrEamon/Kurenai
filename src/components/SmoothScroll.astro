---
// Lenis smooth scrolling + page anchor scrolling. Rebuilt after ClientRouter navigation.
---
<script>
  import Lenis from 'lenis';

  let lenis: Lenis | null = null;
  let raf = 0;

  const reduce = matchMedia('(prefers-reduced-motion: reduce)');
  const EASE_ANCHOR = (t: number) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

  function startLenis() {
    if (reduce.matches) return;
    lenis?.destroy();
    cancelAnimationFrame(raf);
    lenis = new Lenis({ lerp: 0.06 });
    (window as any).lenis = lenis;

    const loop = (time: number) => {
      lenis?.raf(time);
      raf = requestAnimationFrame(loop);
    };
    raf = requestAnimationFrame(loop);
  }

  function anchorOffset(target: HTMLElement): number {
    return Number.parseFloat(getComputedStyle(target).scrollMarginTop) || 0;
  }

  function anchorTop(target: HTMLElement): number {
    return target.getBoundingClientRect().top + window.scrollY - anchorOffset(target);
  }

  function gapTo(target: HTMLElement): number {
    return target.getBoundingClientRect().top - anchorOffset(target);
  }

  function scrollToExact(target: HTMLElement) {
    const doc = document.documentElement;
    const max = Math.max(0, doc.scrollHeight - window.innerHeight);
    const top = Math.max(0, Math.min(window.scrollY + gapTo(target), max));
    if (lenis && !reduce.matches) {
      lenis.scrollTo(top, { immediate: true, force: true });
    } else {
      window.scrollTo({ top, behavior: 'auto' });
    }
  }

  function settleAnchor(target: HTMLElement) {
    const correct = () => {
      const gap = gapTo(target);
      if (Math.abs(gap) > 2 && Math.abs(gap) < 80) scrollToExact(target);
    };

    correct();
    window.setTimeout(correct, 80);
    window.setTimeout(correct, 240);
    window.setTimeout(correct, 520);
  }

  document.addEventListener('click', (event) => {
    const anchor = (event.target as HTMLElement).closest?.('a[href^="#"]') as HTMLAnchorElement | null;
    if (!anchor) return;

    const href = anchor.getAttribute('href') || '';
    if (href.length < 2 || href === '#') return;

    const id = decodeURIComponent(href.slice(1));
    const target = document.getElementById(id);
    if (!target) return;

    event.preventDefault();

    const encodedHash = '#' + encodeURIComponent(id);
    let completed = false;

    const done = () => {
      if (completed) return;
      completed = true;

      settleAnchor(target);
      if (location.hash !== encodedHash) history.pushState(null, '', encodedHash);
      window.dispatchEvent(new CustomEvent('anchor-scroll-complete', { detail: { id } }));
    };

    if (Math.abs(gapTo(target)) < 2) {
      done();
      return;
    }

    const native = () => {
      window.scrollTo({ top: anchorTop(target), behavior: reduce.matches ? 'auto' : 'smooth' });
      window.setTimeout(done, reduce.matches ? 0 : 520);
    };

    if (lenis && !reduce.matches) {
      const before = window.scrollY;
      lenis.scrollTo(target, {
        offset: 0,
        duration: 1.0,
        easing: EASE_ANCHOR,
        lock: true,
        force: true,
        onComplete: done,
      });

      window.setTimeout(() => {
        if (!completed && Math.abs(window.scrollY - before) < 2 && Math.abs(gapTo(target)) > 2) native();
      }, 280);
    } else {
      native();
    }
  });

  document.addEventListener('astro:page-load', startLenis);
  document.addEventListener('astro:before-swap', () => {
    lenis?.destroy();
    lenis = null;
    (window as any).lenis = null;
    cancelAnimationFrame(raf);
  });
</script>
