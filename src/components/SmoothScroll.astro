---
// Lenis 平滑滚动（lerp 0.06）+ 页内锚点(目录/#链接)平滑滚动。reduced-motion 下不启用。ClientRouter 导航后重建。
---
<script>
  import Lenis from 'lenis';

  let lenis: Lenis | null = null;
  let raf = 0;

  function startLenis() {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    lenis?.destroy();
    cancelAnimationFrame(raf);
    lenis = new Lenis({ lerp: 0.06 });
    (window as any).lenis = lenis;
    const loop = (t: number) => {
      lenis?.raf(t);
      raf = requestAnimationFrame(loop);
    };
    raf = requestAnimationFrame(loop);
  }

  // 锚点平滑滚动：目录项与页内 #链接走 Lenis。绑定一次（document 跨导航保留）。
  // 顶部避让只认标题的 scroll-margin-top(=--anchor-offset)；Lenis 1.3.23 的 scrollTo 已读取它，
  // 故 offset 传 0，避免与 scroll-margin-top 双重叠加（之前 offset:-90 会多滚 ~90px）。
  const EASE_ANCHOR = (t: number) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2); // easeInOutCubic
  const reduce = matchMedia('(prefers-reduced-motion: reduce)');

  document.addEventListener('click', (e) => {
    const a = (e.target as HTMLElement).closest?.('a[href^="#"]') as HTMLAnchorElement | null;
    if (!a) return;
    const href = a.getAttribute('href') || '';
    if (href.length < 2 || href === '#') return;
    const id = decodeURIComponent(href.slice(1));
    const target = document.getElementById(id);
    if (!target) return;
    e.preventDefault();

    const encodedHash = '#' + encodeURIComponent(id);
    const done = () => {
      if (location.hash !== encodedHash) history.pushState(null, '', encodedHash);
      // 通知目录：跳转抵达，可解除高亮抑制（比按位置猜更可靠，尤其末节贴底滚不到顶时）
      window.dispatchEvent(new CustomEvent('anchor-scroll-complete', { detail: { id } }));
    };

    if (lenis && !reduce.matches) {
      // offset:0 → 用标题 scroll-margin-top 定位；lock 防止动画途中被滚轮打断，force 允许连点改向
      lenis.scrollTo(target, { offset: 0, duration: 1.0, easing: EASE_ANCHOR, lock: true, force: true, onComplete: done });
    } else {
      target.scrollIntoView({ behavior: reduce.matches ? 'auto' : 'smooth', block: 'start' });
      setTimeout(done, reduce.matches ? 0 : 400);
    }
  });

  document.addEventListener('astro:page-load', startLenis);
  document.addEventListener('astro:before-swap', () => {
    lenis?.destroy();
    lenis = null;
    (window as any).lenis = null;
    cancelAnimationFrame(raf);
  });
</script>
