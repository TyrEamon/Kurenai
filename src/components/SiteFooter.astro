---
import WordmarkRoll from './WordmarkRoll.astro';
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const githubUrl = 'https://github.com/TyrEamon';
const licenseUrl = 'https://creativecommons.org/licenses/by-nc-sa/4.0/';
---

<footer class="site-footer">
  <div class="foot-info foot-info-desktop wrap">
    <div class="foot-group foot-group-left">
      <p>
        &copy; 2024 - {year}
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" data-cursor>TyrEamon</a>，采用
        <a href={licenseUrl} target="_blank" rel="noopener noreferrer" data-cursor>CC BY-NC-SA 4.0</a> 许可
      </p>
      <p>
        <a href={`${base}rss.xml`} data-cursor>RSS</a> /
        <a href={`${base}sitemap-index.xml`} data-cursor>网站地图</a>
      </p>
    </div>

    <div class="foot-group foot-group-right">
      <p>
        由 <a href="https://astro.build/" target="_blank" rel="noopener noreferrer" data-cursor>Astro</a> 和
        <a href="https://www.cloudflare.com/" target="_blank" rel="noopener noreferrer" data-cursor>Cloudflare</a> 强力驱动
      </p>
      <p>本站源码 <span class="source-status">未开源</span></p>
    </div>
  </div>

  <div class="foot-info-mobile wrap" aria-label="站点页脚信息">
    <p>
      &copy; 2024 - {year}
      <a href={githubUrl} target="_blank" rel="noopener noreferrer" data-cursor>TyrEamon</a>
    </p>
    <p>
      <a href={licenseUrl} target="_blank" rel="noopener noreferrer" data-cursor>CC BY-NC-SA 4.0</a>
    </p>
    <p>
      <a href={`${base}rss.xml`} data-cursor>RSS</a> /
      <a href={`${base}sitemap-index.xml`} data-cursor>网站地图</a>
    </p>
    <p>
      <a href="https://astro.build/" target="_blank" rel="noopener noreferrer" data-cursor>Astro</a> /
      <a href="https://www.cloudflare.com/" target="_blank" rel="noopener noreferrer" data-cursor>Cloudflare</a> · 未开源
    </p>
  </div>

  <div class="foot-name wrap" aria-hidden="true">
    <WordmarkRoll text="RUNEBYTE." />
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    margin-top: 6rem;
    padding-block: 2.8rem 0.75rem;
    overflow: hidden;
  }

  .foot-info,
  .foot-info-mobile {
    color: var(--fg-faint);
    font-size: 0.86rem;
    line-height: 1.9;
    text-wrap: pretty;
  }

  .foot-info-desktop {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: start;
    gap: 1.6rem 4rem;
    text-align: left;
  }

  .foot-info-mobile {
    display: none;
  }

  .foot-group {
    display: flex;
    flex-direction: column;
    gap: 0.26rem;
    min-width: 0;
  }

  .foot-group-right {
    text-align: right;
  }

  .foot-info p,
  .foot-info-mobile p {
    margin: 0;
  }

  .foot-info a,
  .foot-info-mobile a {
    color: var(--fg-dim);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color 180ms ease,
      border-color 180ms ease;
  }

  .foot-info a:hover,
  .foot-info-mobile a:hover {
    color: var(--accent);
    border-bottom-color: color-mix(in srgb, var(--accent) 58%, transparent);
  }

  .foot-info a:focus-visible,
  .foot-info-mobile a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 0.22rem;
  }

  .source-status {
    color: var(--fg-dim);
  }

  .foot-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 11.5rem;
    line-height: 0.9;
    letter-spacing: 0;
    color: var(--fg);
    margin-top: 1.45rem;
    text-align: left;
    white-space: nowrap;
  }

  @media (max-width: 1280px) {
    .foot-name {
      font-size: 10.4rem;
    }
  }

  @media (max-width: 1080px) {
    .foot-name {
      font-size: 8.2rem;
    }
  }

  @media (max-width: 860px) {
    .site-footer {
      margin-top: 4rem;
      padding-block: 2rem 0.7rem;
    }

    .foot-info-desktop {
      display: none;
    }

    .foot-info-mobile {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, max-content);
      align-items: baseline;
      gap: 0.22rem 0.75rem;
      font-size: 0.76rem;
      line-height: 1.5;
    }

    .foot-info-mobile p:nth-child(even) {
      text-align: right;
      white-space: nowrap;
    }

    .foot-name {
      font-size: 6rem;
      margin-top: 1.1rem;
    }
  }

  @media (max-width: 520px) {
    .foot-info-mobile {
      gap: 0.18rem 0.55rem;
      font-size: 0.7rem;
    }

    .foot-name {
      font-size: 4.35rem;
      margin-top: 1rem;
    }
  }

  @media (max-width: 370px) {
    .foot-info-mobile {
      font-size: 0.66rem;
    }

    .foot-name {
      font-size: 3.85rem;
    }
  }
</style>
