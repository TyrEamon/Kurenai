---
import ThemeToggle from './ThemeToggle.astro';
const base = import.meta.env.BASE_URL;
const nav = [
  { href: `${base}blog/`, label: '文章' },
  { href: `${base}notes/`, label: '手记' },
  { href: `${base}tags/`, label: '标签' },
  { href: `${base}archive/`, label: '归档' },
  { href: `${base}friends/`, label: '友链' },
  { href: `${base}about/`, label: '关于' },
];
const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={base} data-cursor aria-label="RuneByte 首页">RuneByte<span class="dot">.</span></a>
    <nav class="nav" aria-label="主导航">
      {
        nav.map((item) => (
          <a
            href={item.href}
            data-cursor
            class:list={['nav-link', { active: path === item.href }]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="actions">
      <a class="icon-btn" href={`${base}search/`} data-cursor aria-label="搜索">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    width: 100%;
    min-height: 4rem;
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.4rem);
    padding: 0.75rem var(--pad);
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.18rem;
    letter-spacing: -0.02em;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }
  .brand:hover {
    opacity: 0.78;
  }
  .brand .dot {
    color: var(--accent);
  }
  .nav {
    display: flex;
    align-items: center;
    gap: clamp(0.9rem, 2vw, 1.8rem);
    flex-wrap: wrap;
    margin-left: auto;
  }
  .nav-link {
    position: relative;
    padding: 0.35rem 0.1rem;
    font-size: 0.95rem;
    color: var(--fg-dim);
    transition: color 0.2s;
  }
  /* 下划线从左生长(悬停)/常驻(当前页) */
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    border-radius: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.35s var(--ease);
  }
  .nav-link:hover {
    color: var(--fg);
  }
  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  .nav-link.active {
    color: var(--fg);
  }
  .nav-link.active::after {
    transform: scaleX(1);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-shrink: 0;
  }
  .icon-btn {
    width: 2.2rem;
    height: 2.2rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--fg-dim);
    transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.2s var(--ease);
  }
  .icon-btn:hover {
    color: var(--fg);
    border-color: var(--line-strong);
    background: color-mix(in srgb, var(--fg) 6%, transparent);
  }
  .icon-btn:active {
    transform: scale(0.9);
  }
  @media (max-width: 600px) {
    .header-inner {
      min-height: 3.5rem;
      gap: 0.8rem;
    }
    .nav {
      gap: 0.85rem;
    }
    .nav-link {
      font-size: 0.9rem;
    }
  }
</style>
