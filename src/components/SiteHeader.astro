---
import ThemeToggle from './ThemeToggle.astro';
import WordmarkRoll from './WordmarkRoll.astro';
const base = import.meta.env.BASE_URL;
const nav = [
  { href: `${base}blog/`, label: '文章' },
  { href: `${base}notes/`, label: '手记' },
  { href: `${base}tags/`, label: '标签' },
  { href: `${base}archive/`, label: '归档' },
  { href: `${base}gallery/`, label: '图集' },
  { href: `${base}friends/`, label: '友链' },
  { href: `${base}about/`, label: '关于' },
];
const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={base} data-cursor aria-label="RuneByte 首页">
      <WordmarkRoll text="RuneByte." />
    </a>
    <nav class="nav" aria-label="主导航">
      {
        nav.map((item) => (
          <a
            href={item.href}
            data-cursor
            class:list={['nav-link', { active: path === item.href }]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="actions">
      <button class="icon-btn search-trigger" type="button" data-cursor aria-label="搜索（快捷键 / 或 Ctrl/⌘K）">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </button>
      <ThemeToggle />
      <button class="icon-btn menu-toggle" type="button" data-cursor aria-label="打开导航菜单" aria-controls="mobile-nav-panel" aria-expanded="false">
        <svg class="menu-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line class="menu-line menu-line-top" x1="5" y1="7" x2="19" y2="7" />
          <line class="menu-line menu-line-mid" x1="5" y1="12" x2="19" y2="12" />
          <line class="menu-line menu-line-bot" x1="5" y1="17" x2="19" y2="17" />
        </svg>
      </button>
    </div>
  </div>
  <nav id="mobile-nav-panel" class="mobile-nav" aria-label="移动端导航" hidden>
    {
      nav.map((item) => (
        <a
          href={item.href}
          data-cursor
          class:list={['mobile-nav-link', { active: path === item.href }]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    width: 100%;
    min-height: 4rem;
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.4rem);
    padding: 0.75rem var(--pad);
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.18rem;
    letter-spacing: -0.02em;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: clamp(0.9rem, 2vw, 1.8rem);
    flex-wrap: wrap;
    margin-left: auto;
  }
  .nav-link {
    position: relative;
    padding: 0.35rem 0.1rem;
    font-size: 0.95rem;
    color: var(--fg-dim);
    transition: color 0.2s;
  }
  /* 下划线从左生长(悬停)/常驻(当前页) */
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    border-radius: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.35s var(--ease);
  }
  .nav-link:hover {
    color: var(--fg);
  }
  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  .nav-link.active {
    color: var(--fg);
  }
  .nav-link.active::after {
    transform: scaleX(1);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-shrink: 0;
  }
  .icon-btn {
    width: 2.2rem;
    height: 2.2rem;
    display: grid;
    place-items: center;
    padding: 0;
    background: none;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--fg-dim);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.2s var(--ease);
  }
  .icon-btn:hover {
    color: var(--fg);
    border-color: var(--line-strong);
    background: color-mix(in srgb, var(--fg) 6%, transparent);
  }
  .icon-btn:active {
    transform: scale(0.9);
  }
  .menu-toggle {
    display: none;
  }
  .menu-icon {
    overflow: visible;
  }
  .menu-line {
    transform-box: fill-box;
    transform-origin: center;
    transition: opacity 0.2s var(--ease), transform 0.26s var(--ease);
  }
  .menu-toggle.is-open .menu-line-top {
    transform: translateY(5px) rotate(45deg);
  }
  .menu-toggle.is-open .menu-line-mid {
    opacity: 0;
    transform: scaleX(0.35);
  }
  .menu-toggle.is-open .menu-line-bot {
    transform: translateY(-5px) rotate(-45deg);
  }
  .mobile-nav {
    display: none;
  }
  .mobile-nav-link {
    display: flex;
    align-items: center;
    min-height: 2.4rem;
    padding: 0.48rem 0.7rem;
    border-radius: 6px;
    color: var(--fg-dim);
    font-size: 0.94rem;
    transition: color 0.2s, background 0.2s;
  }
  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--fg);
    background: color-mix(in srgb, var(--fg) 7%, transparent);
  }
  @media (max-width: 600px) {
    .header-inner {
      min-height: 3.5rem;
      gap: 0.65rem;
    }
    .nav {
      display: none;
    }
    .actions {
      margin-left: auto;
    }
    .menu-toggle {
      display: grid;
    }
    .mobile-nav:not([hidden]) {
      position: absolute;
      top: calc(100% + 0.45rem);
      right: var(--pad);
      z-index: 2;
      display: grid;
      width: min(13rem, calc(100vw - var(--pad) * 2));
      padding: 0.45rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--bg) 88%, transparent);
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
      backdrop-filter: blur(16px);
    }
    [data-theme='light'] .mobile-nav:not([hidden]) {
      box-shadow: 0 18px 46px rgba(22, 19, 15, 0.14);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .menu-line {
      transition: none;
    }
  }
</style>

<script>
  function setMobileNav(open: boolean) {
    const btn = document.querySelector<HTMLButtonElement>('.menu-toggle');
    const panel = document.getElementById('mobile-nav-panel');
    if (!btn || !panel) return;
    btn.classList.toggle('is-open', open);
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? '关闭导航菜单' : '打开导航菜单');
    panel.hidden = !open;
  }

  function bindMobileNav() {
    if ((window as any).__runebyteMobileNavBound) return;
    (window as any).__runebyteMobileNavBound = true;

    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      if (!target) return;
      const toggle = target.closest<HTMLButtonElement>('.menu-toggle');
      if (toggle) {
        event.preventDefault();
        setMobileNav(toggle.getAttribute('aria-expanded') !== 'true');
        return;
      }
      if (target.closest('.mobile-nav-link')) {
        setMobileNav(false);
        return;
      }
      if (!target.closest('.site-header')) setMobileNav(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setMobileNav(false);
    });
    window.addEventListener('resize', () => {
      if (window.innerWidth > 600) setMobileNav(false);
    });
    document.addEventListener('astro:before-swap', () => setMobileNav(false));
  }

  document.addEventListener('astro:page-load', bindMobileNav);
</script>
