---
import type { MarkdownHeading } from 'astro';
interface Props {
  headings: MarkdownHeading[];
}
const { headings } = Astro.props;

let n = 0;
const items = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({ ...h, num: h.depth === 2 ? ++n : null }));
---

{
  items.length > 0 && (
    <nav class="toc" aria-label="目录">
      <p class="toc-title eyebrow">目录</p>
      <div class="toc-scroll">
        <span class="toc-marker" aria-hidden="true" />
        <ul>
          {items.map((h) => (
            <li class:list={['toc-item', h.depth === 3 ? 'sub' : 'top']}>
              <a href={`#${h.slug}`} data-toc={h.slug} data-cursor>
                {h.depth === 2 ? (
                  <span class="num">{h.num}</span>
                ) : (
                  <span class="dot" />
                )}
                <span class="txt">{h.text}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  )
}

<style>
  .toc {
    position: sticky;
    top: 6rem;
    font-size: 0.84rem;
  }
  .toc-title {
    margin-bottom: 0.7rem;
  }
  .toc-scroll {
    position: relative;
    max-height: calc(100vh - 11rem);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .toc-scroll::-webkit-scrollbar {
    display: none;
  }
  /* 平滑滑动的当前项高亮 */
  .toc-marker {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 0;
    border-radius: 9px;
    background: color-mix(in srgb, var(--fg) 8%, transparent);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    transition: top 0.35s var(--ease), height 0.35s var(--ease), opacity 0.3s;
  }
  ul {
    list-style: none;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .toc-item a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.6rem;
    border-radius: 9px;
    color: var(--fg-faint);
    line-height: 1.35;
    transition: color 0.2s;
  }
  .toc-item.sub a {
    padding-left: 1.4rem;
  }
  .toc-item a:hover {
    color: var(--fg-dim);
  }
  .toc-item a.active {
    color: var(--fg);
  }
  .num {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1px solid var(--line-strong);
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--fg-faint);
    transition: background 0.25s var(--ease), border-color 0.25s, color 0.25s;
  }
  .dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    margin-inline: 8px;
    border-radius: 50%;
    background: var(--line-strong);
    transition: background 0.25s, transform 0.25s var(--ease);
  }
  .txt {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .toc-item a.active .num {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .toc-item a.active .dot {
    background: var(--accent);
    transform: scale(1.3);
  }
</style>

<script>
  // 目录定位：确定性 scroll 算法（虚拟 section + 阅读线 + 触底夹取），
  // 取代原来观察标题节点的窄 IO 触发带。取舍见 codex-think/research/toc-logic.md §7.1。
  function initToc(): (() => void) | void {
    const nav = document.querySelector<HTMLElement>('.toc');
    if (!nav) return;
    const scroll = nav.querySelector<HTMLElement>('.toc-scroll');
    const marker = nav.querySelector<HTMLElement>('.toc-marker');
    const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>('a[data-toc]'));
    if (!scroll || !marker || !links.length) return;

    const entries = links
      .map((link) => {
        const head = link.dataset.toc ? document.getElementById(link.dataset.toc) : null;
        return head ? { link, head, top: 0 } : null;
      })
      .filter((e): e is { link: HTMLAnchorElement; head: HTMLElement; top: number } => !!e);
    if (!entries.length) return;

    let current = -1;
    let ticking = false;
    let navTarget: HTMLElement | null = null; // 点击锚点跳转期间，抑制目录自动滚动与滚动抢高亮
    let navTimer = 0;

    // 标题的文档绝对位置（滚动时不变；仅 load/resize/正文变高时重量）
    const measure = () => {
      const y = window.scrollY;
      entries.forEach((e) => (e.top = e.head.getBoundingClientRect().top + y));
    };

    // 目录过长时让当前项保持可见
    const keepInView = (link: HTMLAnchorElement) => {
      if (navTarget) return;
      const top = link.offsetTop;
      const bottom = top + link.offsetHeight;
      if (top < scroll.scrollTop + 24 || bottom > scroll.scrollTop + scroll.clientHeight - 24) {
        scroll.scrollTo({ top: top - scroll.clientHeight * 0.45, behavior: 'smooth' });
      }
    };

    const setActive = (idx: number) => {
      if (idx < 0 || idx === current) return;
      current = idx;
      const link = entries[idx].link;
      links.forEach((l) => l.classList.remove('active'));
      link.classList.add('active');
      // 滑动高亮到当前项
      marker.style.top = `${link.offsetTop}px`;
      marker.style.height = `${link.offsetHeight}px`;
      marker.style.opacity = '1';
      keepInView(link);
    };

    // 当前项 = 阅读线（视窗上方约 28%）之上的最后一个标题；触底强制夹到最后一项。
    const activeIndex = () => {
      const y = window.scrollY;
      const doc = document.documentElement;
      if (window.innerHeight + y >= doc.scrollHeight - 2) return entries.length - 1;
      const line = y + Math.max(120, Math.round(window.innerHeight * 0.28));
      let lo = 0;
      let hi = entries.length - 1;
      let ans = 0;
      while (lo <= hi) {
        const mid = (lo + hi) >> 1;
        if (entries[mid].top <= line) {
          ans = mid;
          lo = mid + 1;
        } else {
          hi = mid - 1;
        }
      }
      return ans;
    };

    const update = () => {
      ticking = false;
      if (navTarget) {
        // 跳转抵达目标附近即解除抑制（兜底；主路径靠 anchor-scroll-complete 事件）。
        // 96 = --anchor-offset(6rem)，标题跳转后会停在距顶约这个距离处。
        if (Math.abs(navTarget.getBoundingClientRect().top - 96) < 14) navTarget = null;
        return;
      }
      setActive(activeIndex());
    };
    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };
    const onResize = () => {
      measure();
      requestUpdate();
    };

    nav.addEventListener('click', (e) => {
      const a = (e.target as HTMLElement).closest?.('a[data-toc]') as HTMLAnchorElement | null;
      if (!a) return;
      const idx = entries.findIndex((en) => en.link === a);
      if (idx < 0) return;
      navTarget = entries[idx].head;
      window.clearTimeout(navTimer);
      navTimer = window.setTimeout(() => {
        navTarget = null;
        requestUpdate();
      }, 1200);
      setActive(idx);
    });

    measure();
    setActive(activeIndex());
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', onResize);
    window.addEventListener('load', onResize, { once: true });
    // 点击 TOC 后由 SmoothScroll 派发的事件解除高亮抑制（比按位置判断更稳，末节贴底也能解除）
    const onAnchorComplete = (e: Event) => {
      const id = (e as CustomEvent<{ id: string }>).detail?.id;
      if (navTarget && navTarget.id === id) {
        navTarget = null;
        requestUpdate();
      }
    };
    window.addEventListener('anchor-scroll-complete', onAnchorComplete);
    // 图片懒加载 / 字体替换撑高正文时重新量位
    const prose = document.querySelector('.prose');
    const ro = prose ? new ResizeObserver(onResize) : null;
    if (prose && ro) ro.observe(prose);

    return () => {
      window.removeEventListener('scroll', requestUpdate);
      window.removeEventListener('resize', onResize);
      window.removeEventListener('anchor-scroll-complete', onAnchorComplete);
      window.clearTimeout(navTimer);
      ro?.disconnect();
    };
  }

  // ClientRouter：每次进页重建，离页/再进前清理，避免重复监听器堆积
  let cleanupToc: (() => void) | undefined;
  document.addEventListener('astro:page-load', () => {
    cleanupToc?.();
    cleanupToc = initToc() || undefined;
  });
  document.addEventListener('astro:before-swap', () => {
    cleanupToc?.();
    cleanupToc = undefined;
  });
</script>
