---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length > 0 && (
    <nav class="toc" aria-label="目录">
      <p class="toc-title eyebrow">目录</p>
      <div class="toc-scroll">
        <span class="toc-active-bg" aria-hidden="true" />
        <span class="toc-marker" aria-hidden="true" />
        <ul>
          {items.map((h) => (
            <li class:list={['toc-item', h.depth === 3 ? 'sub' : 'top']}>
              <a href={`#${h.slug}`} data-toc={h.slug} data-cursor>
                <span class="rail-mark" aria-hidden="true" />
                <span class="txt">{h.text}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  )
}

<style>
  .toc {
    position: sticky;
    top: 6rem;
    font-size: 0.84rem;
    --toc-ease: cubic-bezier(0.22, 1, 0.36, 1);
  }

  .toc-title {
    margin-bottom: 0.7rem;
  }

  .toc-scroll {
    --rail-x: 11px;
    position: relative;
    max-height: calc(100vh - 11rem);
    overflow-y: auto;
    scrollbar-width: none;
  }

  .toc-scroll::-webkit-scrollbar {
    display: none;
  }

  .toc-scroll::before {
    content: '';
    position: absolute;
    left: var(--rail-x);
    top: 0.55rem;
    bottom: 0.55rem;
    width: 1px;
    border-radius: 999px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--line-strong) 0.9rem,
      var(--line) calc(100% - 0.9rem),
      transparent
    );
    pointer-events: none;
    z-index: 1;
  }

  .toc-active-bg {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 0;
    border-radius: 8px;
    background: color-mix(in srgb, var(--fg) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--fg) 8%, transparent);
    opacity: 0;
    pointer-events: none;
    transform: translateY(0);
    transition:
      transform 0.46s var(--toc-ease),
      height 0.46s var(--toc-ease),
      opacity 0.24s ease,
      background-color 0.25s ease,
      border-color 0.25s ease;
    will-change: transform, height;
    z-index: 0;
  }

  .toc-marker {
    position: absolute;
    left: var(--rail-x);
    top: 0;
    width: 1px;
    height: 0;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 12px color-mix(in srgb, var(--accent) 42%, transparent);
    opacity: 0;
    pointer-events: none;
    transform: translateY(0);
    transition:
      transform 0.46s var(--toc-ease),
      height 0.46s var(--toc-ease),
      opacity 0.24s ease;
    will-change: transform, height;
    z-index: 1;
  }

  ul {
    list-style: none;
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 0.02rem;
  }

  .toc-item a {
    display: grid;
    grid-template-columns: 22px minmax(0, 1fr);
    align-items: center;
    gap: 0.45rem;
    min-height: 2rem;
    padding: 0.36rem 0.2rem;
    border-radius: 6px;
    color: var(--fg-faint);
    line-height: 1.35;
    transition: color 0.22s ease, transform 0.22s var(--toc-ease);
  }

  .toc-item.sub a {
    min-height: 1.7rem;
    padding-block: 0.24rem;
  }

  .toc-item a:hover {
    color: var(--fg-dim);
  }

  .toc-item a.active {
    color: var(--fg);
  }

  .rail-mark {
    position: relative;
    z-index: 2;
    justify-self: center;
    width: 10px;
    height: 10px;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    background: var(--bg);
    box-shadow: 0 0 0 4px var(--bg);
    transition:
      background 0.28s var(--toc-ease),
      border-color 0.28s ease,
      transform 0.28s var(--toc-ease),
      opacity 0.28s ease;
  }

  .toc-item.sub .rail-mark {
    width: 4px;
    height: 4px;
    border: 0;
    background: transparent;
    box-shadow: none;
    opacity: 0;
  }

  .txt {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .toc-item.top .txt {
    font-weight: 600;
  }

  .toc-item.sub .txt {
    font-size: 0.79rem;
  }

  .toc-item a.active .rail-mark {
    background: var(--accent);
    border-color: var(--accent);
    transform: scale(1.15);
  }

  .toc-item.sub a.active .rail-mark {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .toc-active-bg,
    .toc-marker,
    .toc-item a,
    .rail-mark {
      transition-duration: 0.01ms;
    }
  }
</style>

<script>
  function initToc(): (() => void) | void {
    const nav = document.querySelector<HTMLElement>('.toc');
    if (!nav) return;

    const scroll = nav.querySelector<HTMLElement>('.toc-scroll');
    const activeBg = nav.querySelector<HTMLElement>('.toc-active-bg');
    const marker = nav.querySelector<HTMLElement>('.toc-marker');
    const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>('a[data-toc]'));
    if (!scroll || !activeBg || !marker || !links.length) return;

    const entries = links
      .map((link) => {
        const head = link.dataset.toc ? document.getElementById(link.dataset.toc) : null;
        const item = link.closest<HTMLElement>('.toc-item');
        return head && item ? { link, head, item, top: 0 } : null;
      })
      .filter(
        (entry): entry is { link: HTMLAnchorElement; head: HTMLElement; item: HTMLElement; top: number } =>
          !!entry,
      );
    if (!entries.length) return;

    let current = -1;
    let ticking = false;
    let navTarget: HTMLElement | null = null;
    let navTimer = 0;

    const measure = () => {
      const y = window.scrollY;
      entries.forEach((entry) => {
        entry.top = entry.head.getBoundingClientRect().top + y;
      });
    };

    const anchorOffset = (target = entries[current]?.head ?? entries[0].head) =>
      Number.parseFloat(getComputedStyle(target).scrollMarginTop) || 96;

    const gapToAnchor = (target: HTMLElement) => target.getBoundingClientRect().top - anchorOffset(target);

    const keepInView = (link: HTMLAnchorElement, force = false) => {
      if (navTarget && !force) return;
      const top = link.offsetTop;
      const bottom = top + link.offsetHeight;
      if (top < scroll.scrollTop + 24 || bottom > scroll.scrollTop + scroll.clientHeight - 24) {
        scroll.scrollTo({ top: top - scroll.clientHeight * 0.45, behavior: 'smooth' });
      }
    };

    const activeGroup = (idx: number) => {
      let start = idx;
      while (start > 0 && entries[start].item.classList.contains('sub')) start -= 1;

      let end = start;
      while (end + 1 < entries.length && entries[end + 1].item.classList.contains('sub')) end += 1;

      const top = entries[start].link.offsetTop;
      const last = entries[end].link;
      return { top, height: last.offsetTop + last.offsetHeight - top };
    };

    const setActive = (idx: number, forceScroll = false) => {
      if (idx < 0 || idx === current) return;
      current = idx;
      const link = entries[idx].link;
      const group = activeGroup(idx);

      links.forEach((item) => item.classList.remove('active'));
      link.classList.add('active');

      activeBg.style.transform = `translateY(${group.top}px)`;
      activeBg.style.height = `${group.height}px`;
      activeBg.style.opacity = '1';
      marker.style.transform = `translateY(${link.offsetTop}px)`;
      marker.style.height = `${link.offsetHeight}px`;
      marker.style.opacity = '1';
      keepInView(link, forceScroll);
    };

    const activeIndex = () => {
      const y = window.scrollY;
      const doc = document.documentElement;
      if (window.innerHeight + y >= doc.scrollHeight - 2) return entries.length - 1;

      const line = y + anchorOffset() + 36;
      let lo = 0;
      let hi = entries.length - 1;
      let ans = 0;
      while (lo <= hi) {
        const mid = (lo + hi) >> 1;
        if (entries[mid].top <= line) {
          ans = mid;
          lo = mid + 1;
        } else {
          hi = mid - 1;
        }
      }
      return ans;
    };

    const update = () => {
      ticking = false;
      if (navTarget) {
        if (Math.abs(gapToAnchor(navTarget)) < 18) navTarget = null;
        return;
      }
      setActive(activeIndex());
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    const onResize = () => {
      measure();
      current = -1;
      setActive(activeIndex());
    };

    const onClick = (event: Event) => {
      const anchor = (event.target as HTMLElement).closest?.('a[data-toc]') as HTMLAnchorElement | null;
      if (!anchor) return;
      const idx = entries.findIndex((entry) => entry.link === anchor);
      if (idx < 0) return;

      navTarget = entries[idx].head;
      window.clearTimeout(navTimer);
      navTimer = window.setTimeout(() => {
        navTarget = null;
        requestUpdate();
      }, 1400);
      setActive(idx, true);
    };

    measure();
    setActive(activeIndex());
    nav.addEventListener('click', onClick);
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', onResize);
    window.addEventListener('load', onResize, { once: true });

    const onAnchorComplete = (event: Event) => {
      const id = (event as CustomEvent<{ id: string }>).detail?.id;
      if (navTarget && navTarget.id === id) {
        navTarget = null;
        requestUpdate();
      }
    };
    window.addEventListener('anchor-scroll-complete', onAnchorComplete);

    const prose = document.querySelector('.prose');
    const ro = prose ? new ResizeObserver(onResize) : null;
    if (prose && ro) ro.observe(prose);

    return () => {
      nav.removeEventListener('click', onClick);
      window.removeEventListener('scroll', requestUpdate);
      window.removeEventListener('resize', onResize);
      window.removeEventListener('anchor-scroll-complete', onAnchorComplete);
      window.clearTimeout(navTimer);
      ro?.disconnect();
    };
  }

  let cleanupToc: (() => void) | undefined;
  document.addEventListener('astro:page-load', () => {
    cleanupToc?.();
    cleanupToc = initToc() || undefined;
  });
  document.addEventListener('astro:before-swap', () => {
    cleanupToc?.();
    cleanupToc = undefined;
  });
</script>
