---
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/bricolage-grotesque';
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import BackgroundGrid from '../components/BackgroundGrid.astro';
import CustomCursor from '../components/CustomCursor.astro';
import SmoothScroll from '../components/SmoothScroll.astro';
import RevealOnScroll from '../components/RevealOnScroll.astro';
import BackToTop from '../components/BackToTop.astro';
import RandomCover from '../components/RandomCover.astro';
import SearchModal from '../components/SearchModal.astro';
import ImageLightbox from '../components/ImageLightbox.astro';
import { analytics } from '../data/analytics';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
  image?: string;
  intro?: boolean;
}

const {
  title,
  description = '素未谋面的你，我是 Tyr。项目复盘与折腾记录。',
  lang = 'zh',
  image,
  intro = false,
} = Astro.props;

const htmlLang = lang === 'en' ? 'en' : 'zh-CN';
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).href : undefined;
const umami = analytics.umami;
const umamiScriptSrc = `${umami.baseUrl}/script.js`;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    {umami.enabled && <link rel="preconnect" href={umami.baseUrl} />}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RuneByte"
      href={new URL('rss.xml', Astro.site)}
    />
    {
      umami.enabled && (
        <script defer src={umamiScriptSrc} data-website-id={umami.websiteId}></script>
      )
    }
    <!-- 主题防闪烁：首屏前同步应用 -->
    <script is:inline>
      (() => {
        const themeColor = { dark: '#0a0a0a', light: '#f4f1ea' };
        const preferredTheme = () =>
          matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        const storedTheme = () => {
          try {
            const value = localStorage.getItem('theme');
            return value === 'light' || value === 'dark' ? value : null;
          } catch {
            return null;
          }
        };
        const applyTheme = (doc = document, forcedTheme) => {
          const theme = forcedTheme || storedTheme() || preferredTheme();
          doc.documentElement.classList.add('js');
          doc.documentElement.dataset.theme = theme;
          doc
            .querySelector('meta[name="theme-color"]')
            ?.setAttribute('content', themeColor[theme]);
          return theme;
        };
        window.__runebyteApplyTheme = applyTheme;
        applyTheme(document);
        if (!window.__runebyteThemeBound) {
          window.__runebyteThemeBound = true;
          document.addEventListener('astro:before-swap', (event) => {
            applyTheme(event.newDocument);
          });
          document.addEventListener('astro:after-swap', () => {
            applyTheme(document);
          });
          window.addEventListener('storage', (event) => {
            if (event.key === 'theme') applyTheme(document);
          });
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <BackgroundGrid />
    <CustomCursor />
    <SiteHeader intro={intro} />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
    <SmoothScroll />
    <RevealOnScroll />
    <BackToTop />
    <RandomCover />
    <SearchModal />
    <ImageLightbox />
    {intro && <slot name="intro" />}
    <script>
      type PostStatKey = 'pageviews' | 'visitors';
      type PostStatsData = Partial<Record<PostStatKey, number>>;
      type UmamiShare = { websiteId: string; token: string };

      const postStatKeys: PostStatKey[] = ['pageviews', 'visitors'];
      const postStatsCacheTTL = 10 * 60 * 1000;
      const umamiShareCacheTTL = 60 * 60 * 1000;
      const sharePromises = new Map<string, Promise<UmamiShare>>();
      const pathStatPromises = new Map<string, Promise<PostStatsData>>();

      function postStatNumber(value: unknown) {
        if (typeof value === 'number') return value;
        if (value && typeof value === 'object' && 'value' in value) return Number(value.value) || 0;
        return 0;
      }

      function formatPostStat(value: number) {
        return Number.isFinite(value) ? String(Math.max(0, Math.round(value))) : '--';
      }

      function getPostStatsCacheKey(block: HTMLElement) {
        return `runebyte:post-stats:${block.dataset.umamiBase}:${block.dataset.umamiShare}:${block.dataset.postSlug}`;
      }

      function getUmamiShareCacheKey(baseUrl: string, shareId: string) {
        return `runebyte:umami-share:${baseUrl}:${shareId}`;
      }

      function readPostStatsCache(block: HTMLElement): PostStatsData | null {
        try {
          const cached = localStorage.getItem(getPostStatsCacheKey(block));
          if (!cached) return null;
          const parsed = JSON.parse(cached);
          if (Date.now() - parsed.timestamp > postStatsCacheTTL) return null;
          return parsed.value;
        } catch {
          localStorage.removeItem(getPostStatsCacheKey(block));
          return null;
        }
      }

      function writePostStatsCache(block: HTMLElement, stats: PostStatsData) {
        try {
          localStorage.setItem(getPostStatsCacheKey(block), JSON.stringify({ timestamp: Date.now(), value: stats }));
        } catch {}
      }

      function renderPostStats(block: HTMLElement, stats: PostStatsData, animate = true) {
        postStatKeys.forEach((key) => {
          const target = block.querySelector<HTMLElement>(`[data-post-stat-value="${key}"]`);
          if (!target) return;
          const value = Number(stats[key] || 0);
          if (!animate || matchMedia('(prefers-reduced-motion: reduce)').matches) {
            target.textContent = formatPostStat(value);
            return;
          }
          const startText = target.textContent?.replace(/[^\d]/g, '') || '0';
          const start = Number.parseInt(startText, 10) || 0;
          if (start === value) {
            target.textContent = formatPostStat(value);
            return;
          }
          const duration = 620;
          const startedAt = performance.now();
          const tick = (now: number) => {
            const progress = Math.min(1, (now - startedAt) / duration);
            const eased = 1 - Math.pow(1 - progress, 3);
            target.textContent = formatPostStat(start + (value - start) * eased);
            if (progress < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        });
      }

      function getCachedUmamiShare(baseUrl: string, shareId: string, forceRefresh = false): Promise<UmamiShare> {
        const cacheKey = getUmamiShareCacheKey(baseUrl, shareId);
        const promiseKey = `${cacheKey}:${forceRefresh ? 'fresh' : 'cached'}`;
        if (sharePromises.has(promiseKey)) return sharePromises.get(promiseKey)!;
        const promise = (async () => {
          try {
            if (forceRefresh) localStorage.removeItem(cacheKey);
            else {
              const cached = localStorage.getItem(cacheKey);
              if (cached) {
                const parsed = JSON.parse(cached);
                if (Date.now() - parsed.timestamp < umamiShareCacheTTL) return parsed.value;
              }
            }
          } catch {
            localStorage.removeItem(cacheKey);
          }
          const response = await fetch(`${baseUrl}/api/share/${shareId}`);
          if (!response.ok) throw new Error('Failed to load Umami share token');
          const value = await response.json();
          try {
            localStorage.setItem(cacheKey, JSON.stringify({ timestamp: Date.now(), value }));
          } catch {}
          return value;
        })();
        sharePromises.set(promiseKey, promise);
        promise.catch(() => sharePromises.delete(promiseKey));
        return promise;
      }

      async function fetchPathStats(block: HTMLElement, path: string, retry = false): Promise<PostStatsData> {
        const baseUrl = block.dataset.umamiBase;
        const shareId = block.dataset.umamiShare;
        if (!baseUrl || !shareId) return {};
        const cacheKey = `${baseUrl}:${shareId}:${path}:${retry ? 'retry' : 'once'}`;
        if (pathStatPromises.has(cacheKey)) return pathStatPromises.get(cacheKey)!;
        const promise = (async () => {
          const { websiteId, token } = await getCachedUmamiShare(baseUrl, shareId, retry);
          const query = new URLSearchParams({
            startAt: '0',
            endAt: String(Date.now()),
            unit: 'hour',
            timezone: block.dataset.umamiTimezone || 'Asia/Shanghai',
            path: `eq.${path}`,
          });
          const response = await fetch(`${baseUrl}/api/websites/${websiteId}/stats?${query}`, {
            headers: {
              'x-umami-share-token': token,
              'x-umami-share-context': '1',
            },
          });
          if (response.status === 401 && !retry) return fetchPathStats(block, path, true);
          if (!response.ok) throw new Error('Failed to load Umami post stats');
          const stats = await response.json();
          return {
            pageviews: postStatNumber(stats.pageviews),
            visitors: postStatNumber(stats.visitors),
          };
        })();
        pathStatPromises.set(cacheKey, promise);
        promise.catch(() => pathStatPromises.delete(cacheKey));
        return promise;
      }

      function pathsFromBlock(block: HTMLElement) {
        try {
          const parsed = JSON.parse(block.dataset.postPaths || '[]');
          return Array.isArray(parsed) ? parsed.filter((path) => typeof path === 'string') : [];
        } catch {
          return [];
        }
      }

      async function fetchPostStats(block: HTMLElement): Promise<PostStatsData> {
        const results = await Promise.allSettled(pathsFromBlock(block).map((path) => fetchPathStats(block, path)));
        return results.reduce<PostStatsData>(
          (sum, result) => {
            if (result.status !== 'fulfilled') return sum;
            return {
              pageviews: (sum.pageviews || 0) + (result.value.pageviews || 0),
              visitors: (sum.visitors || 0) + (result.value.visitors || 0),
            };
          },
          { pageviews: 0, visitors: 0 },
        );
      }

      function initPostStats() {
        document.querySelectorAll<HTMLElement>('[data-post-stats]').forEach((block) => {
          if (block.dataset.loaded === '1') return;
          block.dataset.loaded = '1';
          const cachedStats = readPostStatsCache(block);
          if (cachedStats) renderPostStats(block, cachedStats, false);
          if (!cachedStats) block.classList.add('is-loading');
          fetchPostStats(block)
            .then((stats) => {
              writePostStatsCache(block, stats);
              renderPostStats(block, stats, true);
            })
            .catch(() => {
              if (!cachedStats) renderPostStats(block, { pageviews: 0, visitors: 0 }, false);
            })
            .finally(() => block.classList.remove('is-loading'));
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initPostStats, { once: true });
      } else {
        initPostStats();
      }
      document.addEventListener('astro:page-load', initPostStats);
    </script>
  </body>
</html>
