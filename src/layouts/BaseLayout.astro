---
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/bricolage-grotesque';
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import BackgroundGrid from '../components/BackgroundGrid.astro';
import CustomCursor from '../components/CustomCursor.astro';
import SmoothScroll from '../components/SmoothScroll.astro';
import RevealOnScroll from '../components/RevealOnScroll.astro';
import BackToTop from '../components/BackToTop.astro';
import RandomCover from '../components/RandomCover.astro';
import SearchModal from '../components/SearchModal.astro';
import ImageLightbox from '../components/ImageLightbox.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
  image?: string;
  intro?: boolean;
}

const {
  title,
  description = '素未谋面的你，我是 Tyr。项目复盘与折腾记录。',
  lang = 'zh',
  image,
  intro = false,
} = Astro.props;

const htmlLang = lang === 'en' ? 'en' : 'zh-CN';
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).href : undefined;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RuneByte"
      href={new URL('rss.xml', Astro.site)}
    />
    <!-- 主题防闪烁：首屏前同步应用 -->
    <script is:inline>
      (() => {
        const themeColor = { dark: '#0a0a0a', light: '#f4f1ea' };
        const preferredTheme = () =>
          matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        const storedTheme = () => {
          try {
            const value = localStorage.getItem('theme');
            return value === 'light' || value === 'dark' ? value : null;
          } catch {
            return null;
          }
        };
        const applyTheme = (doc = document, forcedTheme) => {
          const theme = forcedTheme || storedTheme() || preferredTheme();
          doc.documentElement.classList.add('js');
          doc.documentElement.dataset.theme = theme;
          doc
            .querySelector('meta[name="theme-color"]')
            ?.setAttribute('content', themeColor[theme]);
          return theme;
        };
        window.__runebyteApplyTheme = applyTheme;
        applyTheme(document);
        if (!window.__runebyteThemeBound) {
          window.__runebyteThemeBound = true;
          document.addEventListener('astro:before-swap', (event) => {
            applyTheme(event.newDocument);
          });
          document.addEventListener('astro:after-swap', () => {
            applyTheme(document);
          });
          window.addEventListener('storage', (event) => {
            if (event.key === 'theme') applyTheme(document);
          });
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <BackgroundGrid />
    <CustomCursor />
    <SiteHeader intro={intro} />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
    <SmoothScroll />
    <RevealOnScroll />
    <BackToTop />
    <RandomCover />
    <SearchModal />
    <ImageLightbox />
    {intro && <slot name="intro" />}
  </body>
</html>
