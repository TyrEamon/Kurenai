---
import BaseLayout from '../layouts/BaseLayout.astro';
import IntroAnimation from '../components/IntroAnimation.astro';
import HeroStreams from '../components/HeroStreams.astro';
import PostCard from '../components/PostCard.astro';
import SocialIcons from '../components/SocialIcons.astro';
import { analytics } from '../data/analytics';
import { profile } from '../data/profile';
import { getArticles, getPublishedPosts, getAllTags, wordCount } from '../lib/posts';

const articles = await getArticles();
const all = await getPublishedPosts();
const feed = articles;
const totalWords = all.reduce((sum, post) => sum + wordCount(post.body, post.data.lang), 0);
const formatWan = (n: number) =>
  n >= 10000 ? `${(n / 10000).toFixed(1).replace(/\.0$/, '')}w` : String(n);
// 导航类统计（可点击）：归档=文章数。
const navStats = [
  { label: '归档', value: String(all.length), href: 'archive/' },
  { label: '分类', value: String(new Set(all.map((p) => p.data.category).filter(Boolean)).size), href: 'tags/' },
  { label: '标签', value: String(getAllTags(all).length), href: 'tags/' },
];
const umami = analytics.umami;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="RuneByte · Experiments and Reviews" intro>
  <IntroAnimation />

  <section class="hero">
    <HeroStreams />
    <div class="hero-bg" aria-hidden="true">
      <img src={`${base}site/hero-eyes.webp`} alt="" width="1536" height="1024" decoding="async" />
    </div>
    <div class="wrap">
      <p class="eyebrow">Experiments and Reviews</p>
      <h1 class="hero-name">RuneByte<span class="dot">.</span></h1>
      <p class="hero-quote" data-typewrite>
        回忆是一条<strong><em>没有归途</em></strong>的路，<em>记录即是存档</em>。那些曾经折腾过的<strong><em>项目</em></strong>、修复过的<strong><em>错误</em></strong>、深夜浮现的<strong>灵感</strong>，以及无法重来的<strong><em>手记片段</em></strong>，都将在此慢慢留存。
      </p>
      <a class="hero-cue" href="#enter" data-cursor>↓ scroll</a>
    </div>
  </section>

  <div class="wrap" id="enter">
    <div class="divider"></div>
  </div>

  <div class="home-main wrap">
    <!-- 左：个人简介侧栏 -->
    <aside class="profile-card" data-reveal>
      <img class="pc-avatar" src={profile.avatar} alt={profile.name} width="84" height="84" />
      <div class="pc-name">RuneByte<span class="dot">.</span></div>
      <div class="pc-by">{profile.name}</div>
      <div class="pc-bio">
        <p class="pc-bio-main">{profile.tagline}</p>
        {profile.taglineSub.map((t) => <p class="pc-bio-sub">{t}</p>)}
      </div>
      <div class="pc-rule"></div>
      <p class="pc-motto">{profile.motto}</p>
      <div
        class="pc-stats"
        data-site-stats
        data-umami-enabled={String(umami.enabled)}
        data-umami-base={umami.baseUrl}
        data-umami-share={umami.shareId}
        data-umami-timezone={umami.timezone}
      >
        {
          navStats.map((s) => (
            <a class="pc-stat" href={`${base}${s.href}`} data-cursor>
              <span class="sv">{s.value}</span>
              <span class="sl">{s.label}</span>
            </a>
          ))
        }
        <div class="pc-stat">
          <span class="sv">{formatWan(totalWords)}</span>
          <span class="sl">字数</span>
        </div>
        <div class="pc-stat is-remote">
          <span class="sv" data-stat-value="pageviews">--</span>
          <span class="sl">访问</span>
        </div>
        <div class="pc-stat is-remote">
          <span class="sv" data-stat-value="visitors">--</span>
          <span class="sl">访客</span>
        </div>
      </div>
      <div class="pc-social">
        <SocialIcons size={1.35} />
      </div>
    </aside>

    <!-- 右：文章流 -->
    <div class="home-feed">
      <div class="sec-head" data-reveal>
        <p class="eyebrow">All · 全部文章</p>
        <a class="more" href={`${base}blog/`} data-cursor>纯文本阅读 →</a>
      </div>
      <div class="list">
        {
          feed.map((post, i) => (
            <div data-reveal style={`transition-delay:${Math.min(i, 6) * 45}ms`}>
              <PostCard post={post} />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  /* Hero banner 母题：扣图红瞳，仅首屏出现；遮罩溶进黑底，藏在大字之后 —— 偏离 §8#2 的有意决定 */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero .wrap {
    position: relative;
    z-index: 1;
  }
  .hero-bg img {
    position: absolute;
    top: 50%;
    right: 1%;
    width: min(72vw, 1040px);
    height: auto;
    transform: translateY(-50%);
    opacity: 0.85;
    /* 左侧溶进黑底（让出文字），右缘轻收 —— 去掉扣图的硬边「贴纸感」 */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      transparent 10%,
      #000 30%,
      #000 90%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      transparent 10%,
      #000 30%,
      #000 90%,
      transparent 100%
    );
    /* 氛围呼吸：缓慢上下浮动（reduced-motion 下全局自动失效） */
    animation: heroFloat 7s ease-in-out infinite;
    will-change: transform;
  }
  /* 浅色（阅读态）：扣图深色线条在米白上更跳，压低存在感 */
  [data-theme='light'] .hero-bg img {
    opacity: 0.4;
  }
  @keyframes heroFloat {
    0%,
    100% {
      transform: translateY(-50%);
    }
    50% {
      transform: translateY(calc(-50% - 7px));
    }
  }

  /* —— 撕裂入场 + 红瞳呼吸光（仅首屏；reduced-motion 下全局自动失效）—— */
  .hero-bg img {
    transition: clip-path 1.05s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.85s ease-out;
  }
  /* 入场前合上：撕裂口闭合 + 透明（仅 JS 生效，no-JS 仍正常显示） */
  .js .hero:not(.is-revealed) .hero-bg img {
    opacity: 0;
    clip-path: inset(50% 0 50% 0);
  }
  /* 红瞳呼吸光：眼睛区域一团极淡红光（落点可调 right / top / width） */
  .hero-bg::after {
    content: '';
    position: absolute;
    top: 50%;
    right: calc(1% + min(36vw, 520px) - 170px);
    width: 340px;
    height: 240px;
    transform: translateY(-50%);
    background: radial-gradient(
      ellipse at center,
      rgba(255, 30, 0, 0.5),
      rgba(255, 30, 0, 0) 66%
    );
    mix-blend-mode: screen;
    filter: blur(8px);
    opacity: 0;
    pointer-events: none;
  }
  .hero.is-revealed .hero-bg::after {
    animation: eyeGlow 5s ease-in-out infinite;
  }
  @keyframes eyeGlow {
    0%,
    100% {
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
  }
  .divider {
    border-top: 1px dashed var(--line-strong);
    margin-bottom: 2.6rem;
  }
  .hero-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.4rem, 17vw, 13rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    margin: 0.3em 0 0.25em;
  }
  .hero-name .dot {
    color: var(--accent);
  }
  .hero-quote {
    max-width: 54ch;
    font-family: 'Noto Serif SC', 'Source Han Serif SC', 'Source Han Serif CN', '思源宋体', var(--font-zh-display);
    font-size: clamp(1.02rem, 1.65vw, 1.36rem);
    font-weight: 500;
    line-height: 1.78;
    letter-spacing: 0.02em;
    color: var(--fg-dim);
    text-wrap: pretty;
  }
  .hero-quote strong {
    font-weight: 700;
    color: var(--fg);
  }
  .hero-quote em {
    color: var(--fg);
    font-style: normal;
    background: linear-gradient(to top, color-mix(in srgb, var(--accent) 22%, transparent) 0 0.36em, transparent 0.36em);
  }
  .hero-quote strong em {
    color: color-mix(in srgb, var(--accent) 76%, var(--fg));
    background: linear-gradient(to top, color-mix(in srgb, var(--accent) 28%, transparent) 0 0.42em, transparent 0.42em);
  }
  :global(.js) .hero-quote[data-typewrite]:not(.is-typewrite-started) {
    visibility: hidden;
  }
  .hero-quote.is-typing::after,
  .hero-quote.is-typed::after {
    content: '';
    display: inline-block;
    width: 0.08em;
    height: 1.08em;
    margin-left: 0.25em;
    vertical-align: -0.14em;
    background: var(--accent);
    animation: quoteCaret 0.86s steps(1) infinite;
  }
  @keyframes quoteCaret {
    50% {
      opacity: 0;
    }
  }
  .hero-cue {
    display: inline-block;
    margin-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    color: var(--fg-faint);
    animation: bob 2s ease-in-out infinite;
  }
  @keyframes bob {
    50% {
      transform: translateY(6px);
    }
  }

  /* 两栏 */
  .home-main {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    padding-bottom: 4rem;
  }
  .profile-card {
    position: sticky;
    top: 6rem;
    align-self: start;
  }
  .pc-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--line-strong);
    margin: 0 0 1.1rem;
  }
  .pc-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.7rem;
    letter-spacing: -0.02em;
  }
  .pc-name .dot {
    color: var(--accent);
  }
  .pc-by {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
    margin-top: 0.35rem;
  }
  .pc-bio {
    position: relative;
    margin-top: 1.15rem;
    padding-left: 0.95rem;
  }
  /* 主句左侧渐隐强调竖条 */
  .pc-bio::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.2rem;
    bottom: 0.2rem;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(to bottom, var(--accent), transparent 85%);
  }
  .pc-bio-main {
    font-family: var(--font-zh-display);
    font-size: 1.04rem;
    line-height: 1.5;
    color: var(--fg);
  }
  .pc-bio-sub {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--fg-dim);
  }
  .pc-bio-sub:first-of-type {
    margin-top: 0.22rem;
  }
  /* 颜文字一行单独拎出来、轻点红 */
  .pc-bio-sub:last-child {
    margin-top: 0.6rem;
    color: color-mix(in srgb, var(--accent) 50%, var(--fg-dim));
  }
  .pc-rule {
    border-top: 1px solid var(--line);
    margin: 1.2rem 0 0.85rem;
    max-width: 11rem;
  }
  .pc-motto {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--fg-faint);
    letter-spacing: 0.02em;
  }
  /* 格言作「注释式签名」收尾 */
  .pc-motto::before {
    content: '// ';
    color: color-mix(in srgb, var(--accent) 60%, var(--fg-faint));
  }
  .pc-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: 0.6rem;
    margin: 1.4rem 0;
    border-top: 1px solid var(--line);
  }
  .pc-stat {
    display: flex;
    flex-direction: column;
    gap: 0.22rem;
    padding: 0.62rem 0;
  }
  .pc-stat:nth-child(n + 4) {
    border-top: 1px solid var(--line);
  }
  .pc-stat .sv {
    font-family: var(--font-display);
    font-size: 1.42rem;
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.02em;
    line-height: 1;
    transition: color 0.2s, opacity 0.2s;
  }
  .pc-stat.is-loading .sv {
    opacity: 0.45;
  }
  a.pc-stat:hover .sv {
    color: var(--accent);
  }
  .pc-stat .sl {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--fg-faint);
  }
  .pc-social {
    display: flex;
    justify-content: flex-start;
  }

  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--line-strong);
    padding-bottom: 0.8rem;
  }
  .home-feed .list {
    display: flex;
    flex-direction: column;
    margin-top: 0.5rem;
  }
  .more {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-dim);
  }
  .more:hover {
    color: var(--accent);
  }

  /* 窄屏：图退成很淡的底纹，偏右下，绝不压住正文可读性 */
  @media (max-width: 720px) {
    .hero-bg img {
      width: 145%;
      right: -32%;
      opacity: 0.3;
    }
    .hero-quote {
      max-width: 31ch;
      font-size: clamp(0.98rem, 4.1vw, 1.12rem);
      line-height: 1.72;
    }
    /* 小字号下色带更薄 → 加高加浓，补回桌面端的高亮存在感 */
    .hero-quote em {
      background: linear-gradient(
        to top,
        color-mix(in srgb, var(--accent) 26%, transparent) 0 0.52em,
        transparent 0.52em
      );
    }
    .hero-quote strong em {
      background: linear-gradient(
        to top,
        color-mix(in srgb, var(--accent) 32%, transparent) 0 0.58em,
        transparent 0.58em
      );
    }
    .hero-bg::after {
      display: none;
    }
    [data-theme='light'] .hero-bg img {
      opacity: 0.22;
    }
  }

  @media (max-width: 860px) {
    .home-main {
      grid-template-columns: 1fr;
    }
    .home-feed {
      order: 1;
    }
    .profile-card {
      position: static;
      order: 2;
      margin-top: 2.4rem;
    }
  }
</style>

<script>
  // 首屏 Hero → 渐入博客：向下滚动/点 ↓scroll/触屏上滑，都平滑「滑入」博客（与点击一致）；
  // Hero 内容随滚动缓慢淡出上移，形成较慢的交叉渐变。正常页面、不锁。
  let off: (() => void) | null = null;
  let quoteTimer: number | null = null;
  let quoteRunId = 0;
  type SiteStatKey = 'pageviews' | 'visitors';
  type SiteStats = Partial<Record<SiteStatKey, number>>;
  const siteStatKeys: SiteStatKey[] = ['pageviews', 'visitors'];
  const siteStatsCacheTTL = 10 * 60 * 1000;

  function formatSiteStat(value: number) {
    return Number.isFinite(value) ? String(Math.max(0, Math.round(value))) : '--';
  }

  function animateStatValue(el: HTMLElement, end: number) {
    const startText = el.textContent?.replace(/[^\d]/g, '') || '0';
    const start = Number.parseInt(startText, 10) || 0;
    if (!Number.isFinite(end) || start === end || matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = formatSiteStat(end);
      return;
    }
    const duration = 760;
    const startedAt = performance.now();
    const tick = (now: number) => {
      const progress = Math.min(1, (now - startedAt) / duration);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = formatSiteStat(start + (end - start) * eased);
      if (progress < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  function getSiteStatsCacheKey(block: HTMLElement) {
    return `runebyte:site-stats:${block.dataset.umamiBase}:${block.dataset.umamiShare}:${
      block.dataset.umamiTimezone || 'Asia/Shanghai'
    }`;
  }

  function readCachedSiteStats(block: HTMLElement): SiteStats | null {
    try {
      const cached = localStorage.getItem(getSiteStatsCacheKey(block));
      if (!cached) return null;
      const parsed = JSON.parse(cached);
      if (Date.now() - parsed.timestamp > siteStatsCacheTTL) return null;
      return parsed.value;
    } catch {
      localStorage.removeItem(getSiteStatsCacheKey(block));
      return null;
    }
  }

  function writeCachedSiteStats(block: HTMLElement, stats: SiteStats) {
    try {
      localStorage.setItem(getSiteStatsCacheKey(block), JSON.stringify({ timestamp: Date.now(), value: stats }));
    } catch {}
  }

  function renderSiteStats(block: HTMLElement, stats: SiteStats, animate = true) {
    siteStatKeys.forEach((key) => {
      const target = block.querySelector<HTMLElement>(`[data-stat-value="${key}"]`);
      if (!target) return;
      const value = Number(stats[key] || 0);
      if (animate) animateStatValue(target, value);
      else target.textContent = formatSiteStat(value);
    });
  }

  function getUmamiShareCacheKey(baseUrl: string, shareId: string) {
    return `runebyte:umami-share:${baseUrl}:${shareId}`;
  }

  async function getUmamiShare(baseUrl: string, shareId: string, forceRefresh = false) {
    const cacheKey = getUmamiShareCacheKey(baseUrl, shareId);
    const cacheTTL = 60 * 60 * 1000;
    try {
      if (forceRefresh) localStorage.removeItem(cacheKey);
      else {
        const cached = localStorage.getItem(cacheKey);
        if (cached) {
          const parsed = JSON.parse(cached);
          if (Date.now() - parsed.timestamp < cacheTTL) return parsed.value;
        }
      }
    } catch {
      localStorage.removeItem(cacheKey);
    }
    const response = await fetch(`${baseUrl}/api/share/${shareId}`);
    if (!response.ok) throw new Error('Failed to load Umami share token');
    const value = await response.json();
    try {
      localStorage.setItem(cacheKey, JSON.stringify({ timestamp: Date.now(), value }));
    } catch {}
    return value;
  }

  async function fetchSiteStats(block: HTMLElement, retry = false) {
    const baseUrl = block.dataset.umamiBase;
    const shareId = block.dataset.umamiShare;
    if (block.dataset.umamiEnabled !== 'true' || !baseUrl || !shareId) return null;
    const query = new URLSearchParams({
      startAt: '0',
      endAt: String(Date.now()),
      unit: 'hour',
      timezone: block.dataset.umamiTimezone || 'Asia/Shanghai',
    });
    const { websiteId, token } = await getUmamiShare(baseUrl, shareId, retry);
    const response = await fetch(`${baseUrl}/api/websites/${websiteId}/stats?${query}`, {
      headers: {
        'x-umami-share-token': token,
        'x-umami-share-context': '1',
      },
    });
    if (response.status === 401 && !retry) return fetchSiteStats(block, true);
    if (!response.ok) throw new Error('Failed to load Umami stats');
    return response.json();
  }

  function initSiteStats() {
    const block = document.querySelector<HTMLElement>('[data-site-stats]');
    if (!block || block.dataset.loaded === '1') return;
    block.dataset.loaded = '1';
    const cachedStats = readCachedSiteStats(block);
    if (cachedStats) renderSiteStats(block, cachedStats, false);
    if (!cachedStats) {
      block.querySelectorAll<HTMLElement>('.is-remote').forEach((item) => item.classList.add('is-loading'));
    }
    fetchSiteStats(block)
      .then((stats) => {
        if (!stats) return;
        writeCachedSiteStats(block, stats);
        renderSiteStats(block, stats, true);
      })
      .catch(() => {
        if (!cachedStats) {
          block.querySelectorAll<HTMLElement>('[data-stat-value]').forEach((target) => {
            target.textContent = '--';
          });
        }
      })
      .finally(() => {
        block.querySelectorAll<HTMLElement>('.is-remote').forEach((item) => item.classList.remove('is-loading'));
      });
  }
 
  function resetQuoteTyping() {
    if (quoteTimer) clearTimeout(quoteTimer);
    quoteTimer = null;
    quoteRunId += 1;
  }
 
  function getQuoteParts(root: HTMLElement) {
    if (!root.dataset.typewriteSource) root.dataset.typewriteSource = root.innerHTML.trim();
    root.innerHTML = root.dataset.typewriteSource;
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        return node.textContent ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
      },
    });
    const parts: { node: Text; text: string }[] = [];
    while (walker.nextNode()) {
      const node = walker.currentNode as Text;
      parts.push({ node, text: node.textContent || '' });
    }
    parts.forEach(({ node }) => (node.textContent = ''));
    return parts;
  }
 
  function setQuoteImmediate(root: HTMLElement) {
    root.innerHTML = root.dataset.typewriteSource || root.innerHTML;
    root.classList.add('is-typewrite-started');
    root.classList.remove('is-typing');
    root.classList.add('is-typed');
  }
 
  function playQuoteTyping() {
    const quote = document.querySelector<HTMLElement>('[data-typewrite]');
    if (!quote) return;
    resetQuoteTyping();
 
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
      setQuoteImmediate(quote);
      return;
    }
 
    const parts = getQuoteParts(quote);
    if (!parts.length) return;
    const runId = quoteRunId;
    quote.classList.add('is-typewrite-started');
    quote.classList.add('is-typing');
    quote.classList.remove('is-typed');
 
    let partIndex = 0;
    let charIndex = 0;
    const tick = () => {
      if (runId !== quoteRunId) return;
      const part = parts[partIndex];
      if (!part) {
        quote.classList.remove('is-typing');
        quote.classList.add('is-typed');
        quoteTimer = null;
        return;
      }
 
      charIndex += 1;
      const typedChar = part.text.charAt(charIndex - 1);
      part.node.textContent = part.text.slice(0, charIndex);

      if (charIndex >= part.text.length) {
        partIndex += 1;
        charIndex = 0;
      }

      const delay = /[，。！？；：,.!?;:]/.test(typedChar) ? 105 : typedChar.trim() ? 36 : 14;
      quoteTimer = window.setTimeout(tick, delay);
    };
 
    quoteTimer = window.setTimeout(tick, 220);
  }
  function initHero() {
    off?.();
    off = null;
    initSiteStats();
    const inner = document.querySelector<HTMLElement>('.hero .wrap');
    const target = document.getElementById('enter');
    if (!inner) return;
    const lenis = () => (window as any).lenis;

    // 渐变（更慢：fade 拉到 0.85 屏高）
    let ticking = false;
    const update = () => {
      const p = Math.min(1, window.scrollY / (innerHeight * 0.85));
      inner.style.opacity = String(1 - p);
      inner.style.transform = `translateY(${-p * 55}px)`;
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    addEventListener('scroll', onScroll, { passive: true });
    update();

    // 一次向下滚动 = 平滑滑入博客（与点 ↓scroll 一致，慢一点）
    let gliding = false;
    const glide = () => {
      if (gliding || !target) return;
      const l = lenis();
      if (!l) {
        window.scrollTo({ top: target.offsetTop - 90, behavior: 'smooth' });
        return;
      }
      gliding = true;
      l.stop(); // 滑入期间忽略滚轮输入，避免与 Lenis 自身滚动打架（抖动）
      l.scrollTo(target, {
        offset: -90,
        duration: 1.8,
        force: true,
        onComplete: () => {
          l.start();
          gliding = false;
        },
      });
    };
    const onWheel = (e: WheelEvent) => {
      if (window.scrollY < 8 && e.deltaY > 0) {
        e.preventDefault();
        glide();
      }
    };
    let ty = 0;
    const onTS = (e: TouchEvent) => (ty = e.touches[0].clientY);
    const onTM = (e: TouchEvent) => {
      if (window.scrollY < 8 && ty - e.touches[0].clientY > 14) glide();
    };
    const onKey = (e: KeyboardEvent) => {
      if (window.scrollY < 8 && [' ', 'ArrowDown', 'PageDown'].includes(e.key)) {
        e.preventDefault();
        glide();
      }
    };
    const cue = inner.querySelector<HTMLElement>('.hero-cue');
    const onCue = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      glide();
    };

    addEventListener('wheel', onWheel, { passive: false });
    addEventListener('touchstart', onTS, { passive: true });
    addEventListener('touchmove', onTM, { passive: true });
    addEventListener('keydown', onKey);
    cue?.addEventListener('click', onCue);

    const heroEl = document.querySelector<HTMLElement>('.hero');

    // 撕裂入场：等入场幕布揭开后给 .hero 挂 is-revealed —— 红瞳沿撕裂口裂开浮现 + 红瞳呼吸光起拍
    let stopReveal: (() => void) | null = null;
    if (heroEl) {
      let revealed = false;
      let revealTimer: number | null = null;
      const reveal = () => {
        if (revealed) return;
        revealed = true;
        heroEl.classList.add('is-revealed');
        window.setTimeout(playQuoteTyping, 140);
      };
      if (!document.getElementById('intro')) {
        reveal(); // 入场层已结束/被跳过：直接揭示
      } else {
        window.addEventListener('runebyte:intro-done', reveal, { once: true });
        revealTimer = window.setTimeout(reveal, 2600); // 兜底：漏接事件也能揭示
        stopReveal = () => {
          window.removeEventListener('runebyte:intro-done', reveal);
          if (revealTimer) clearTimeout(revealTimer);
        };
      }
    }

    off = () => {
      resetQuoteTyping();
      removeEventListener('scroll', onScroll);
      removeEventListener('wheel', onWheel);
      removeEventListener('touchstart', onTS);
      removeEventListener('touchmove', onTM);
      removeEventListener('keydown', onKey);
      cue?.removeEventListener('click', onCue);
      stopReveal?.();
    };
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSiteStats, { once: true });
  } else {
    initSiteStats();
  }
  document.addEventListener('astro:page-load', initHero);
  document.addEventListener('astro:before-swap', () => {
    off?.();
    off = null;
  });
</script>
