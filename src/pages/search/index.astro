---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="搜索 · RuneByte" description="站内搜索">
  <section class="wrap search-launch">
    <p class="eyebrow">Search · 搜索</p>
    <h1>站内搜索</h1>
    <button class="launch-box search-trigger" type="button" data-cursor aria-label="打开搜索">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <span class="lb-text">搜索文章 / 手记 / 标签 / 路径…</span>
      <span class="lb-keys"><kbd>Ctrl</kbd><kbd>K</kbd></span>
    </button>
    <p class="launch-note">也可以在任意页面按 <kbd>/</kbd> 或 <kbd>Ctrl/⌘</kbd> + <kbd>K</kbd> 唤起搜索。</p>
  </section>
</BaseLayout>

<style>
  .search-launch {
    padding-top: clamp(3rem, 12vh, 7rem);
    min-height: 60vh;
  }
  .search-launch h1 {
    font-family: var(--font-zh-display);
    font-size: clamp(2.2rem, 6vw, 4rem);
    margin: 0.3rem 0 1.6rem;
  }
  .launch-box {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    width: min(640px, 100%);
    padding: 1rem 1.1rem;
    background: var(--bg-soft);
    border: 1px solid var(--line-strong);
    border-radius: 12px;
    color: var(--fg-faint);
    cursor: pointer;
    transition: border-color 0.25s var(--ease), background 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .launch-box:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, var(--bg-soft));
    transform: translateY(-1px);
  }
  .launch-box svg {
    flex-shrink: 0;
  }
  .lb-text {
    flex: 1;
    text-align: left;
    font-size: 1rem;
  }
  .lb-keys {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .launch-note {
    margin-top: 1.2rem;
    font-size: 0.85rem;
    color: var(--fg-faint);
  }
  kbd {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    line-height: 1;
    padding: 0.2rem 0.36rem;
    border: 1px solid var(--line);
    border-bottom-width: 2px;
    border-radius: 4px;
    color: var(--fg-dim);
  }
</style>

<script>
  // 进入 /search/ 自动唤起搜索浮层（全局监听器持久，需限定当前就是搜索页）
  function autoOpen() {
    if (!/\/search\/?$/.test(location.pathname)) return;
    (window as any).__openSearch?.();
  }
  document.addEventListener('astro:page-load', autoOpen);
</script>
