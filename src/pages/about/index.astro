---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialIcons from '../../components/SocialIcons.astro';
import { profile } from '../../data/profile';
import { projects } from '../../data/projects';
import { games } from '../../data/games';
import { getPublishedPosts, getAllTags } from '../../lib/posts';

const posts = await getPublishedPosts();
const stats = [
  { label: '归档', value: posts.length, href: 'archive/' },
  { label: '分类', value: new Set(posts.map((p) => p.data.category).filter(Boolean)).size, href: 'tags/' },
  { label: '标签', value: getAllTags(posts).length, href: 'tags/' },
];
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="关于 · RuneByte" description="关于 Tyr 与 RuneByte：自我介绍、个人项目与喜欢的游戏">
  <section class="wrap about">
    <p class="eyebrow">About · 关于</p>

    <div class="profile">
      <div class="avatar-wrap">
        <img class="avatar" src={profile.avatar} alt={profile.name} width="160" height="160" />
        <span class="fc tl"></span><span class="fc tr"></span>
        <span class="fc bl"></span><span class="fc br"></span>
      </div>
      <div class="ident">
        <h1 class="name">{profile.name}<span class="dot">.</span></h1>
        <p class="tagline">{profile.tagline}</p>
        {profile.taglineSub.map((t) => <p class="tsub">{t}</p>)}
        <p class="motto">{profile.motto}</p>
      </div>
    </div>

    <div class="stats">
      {
        stats.map((s) => (
          <a class="stat" href={`${base}${s.href}`} data-cursor>
            <span class="sv">{s.value}</span>
            <span class="sl">{s.label}</span>
          </a>
        ))
      }
    </div>

    <!-- 自我介绍 -->
    <section class="block" data-reveal>
      <p class="eyebrow">Bio · 自我介绍</p>
      <div class="prose bio">
        <p>
          非科班，偶尔有空喜欢捣鼓一些有趣的小项目，也试着把自己的想法和创意做出来。
        </p>
        <p>
          得益于 AI 带来的技术平权，我也能体验一把 <strong>Vibe Coding</strong>，让一些原本停在脑子里的空中楼阁慢慢落地。不过实际玩下来，我感觉 AI 终究还是工具，它更像是<strong>放大个人能力</strong>，而不是替代一切，专业的人会变得更强。但很多细致、专业、需要判断的地方，至少现在还离不开人。
        </p>
        <p>
          这只是我目前对于 Vibe 的观点，而我也是一个门外汉，说的不一定正确。总之，<em>多学、多看、多尝试</em>。
        </p>
      </div>
    </section>

    <!-- 个人项目 -->
    <section class="block" data-reveal>
      <div class="sec-head">
        <p class="eyebrow">Projects · 个人项目</p>
        <a class="more" href={profile.socials[0].url} target="_blank" rel="noopener noreferrer" data-cursor>
          GitHub →
        </a>
      </div>
      <div class="proj-list">
        {
          projects.map((p) => (
            <a class="proj" href={p.url} target="_blank" rel="noopener noreferrer" data-cursor>
              <div class="proj-main">
                <div class="proj-top">
                  <h3 class="proj-name">{p.name}</h3>
                  <span class="proj-arrow">↗</span>
                </div>
                <p class="proj-desc">{p.description}</p>
                <div class="proj-meta">
                  <span class="lang">
                    <span class="lang-dot" style={`background:${p.langColor}`} />
                    {p.lang}
                  </span>
                  {p.stars ? <span class="stat-i">★ {p.stars}</span> : null}
                  {p.forks ? <span class="stat-i">⑂ {p.forks}</span> : null}
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- 喜欢的游戏 -->
    <section class="block" data-reveal>
      <p class="eyebrow">Playing · 喜欢的游戏</p>
      <div class="game-grid">
        {
          games.map((g) => {
            const Tag = g.url ? 'a' : 'div';
            return (
              <Tag
                class="game"
                href={g.url}
                target={g.url ? '_blank' : undefined}
                rel={g.url ? 'noopener noreferrer' : undefined}
                data-cursor={g.url ? '' : undefined}
              >
                <span class="game-cover">
                  {g.cover ? (
                    <img src={g.cover.startsWith('http') ? g.cover : `${base}${g.cover}`} alt={g.title} loading="lazy" />
                  ) : (
                    <span class="game-ph">{g.title.slice(0, 1)}</span>
                  )}
                  <span class="gfc tl" /><span class="gfc br" />
                </span>
                <span class="game-title">{g.title}</span>
                <span class="game-note">{g.note}</span>
              </Tag>
            );
          })
        }
      </div>
    </section>

    <div class="contact" id="contact">
      <p class="eyebrow">Find me</p>
      <SocialIcons size={1.5} />
    </div>

    <a class="back" href={base} data-cursor>← 回首页</a>
  </section>
</BaseLayout>

<style>
  .about {
    padding-top: clamp(3rem, 10vh, 6rem);
    padding-bottom: 4rem;
  }
  .profile {
    display: flex;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    margin: 1.5rem 0 2.5rem;
    flex-wrap: wrap;
  }
  .avatar-wrap {
    position: relative;
    flex-shrink: 0;
    padding: 10px;
  }
  .avatar {
    width: clamp(110px, 22vw, 160px);
    height: clamp(110px, 22vw, 160px);
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--line-strong);
  }
  .fc {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1px solid var(--accent);
  }
  .fc.tl { top: 0; left: 0; border-right: 0; border-bottom: 0; }
  .fc.tr { top: 0; right: 0; border-left: 0; border-bottom: 0; }
  .fc.bl { bottom: 0; left: 0; border-right: 0; border-top: 0; }
  .fc.br { bottom: 0; right: 0; border-left: 0; border-top: 0; }
  .name {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .name .dot {
    color: var(--accent);
  }
  .tagline {
    font-family: var(--font-zh-display);
    font-size: clamp(1.15rem, 2.6vw, 1.6rem);
    margin-top: 0.7rem;
    color: var(--fg);
  }
  .tsub {
    color: var(--fg-dim);
    margin-top: 0.2rem;
  }
  .motto {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg-faint);
    margin-top: 0.9rem;
    letter-spacing: 0.03em;
  }
  .stats {
    display: flex;
    gap: clamp(1.5rem, 5vw, 3.5rem);
    padding: 1.5rem 0;
    border-block: 1px solid var(--line);
    margin-bottom: 3rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .sv {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--fg);
    transition: color 0.2s;
  }
  .stat:hover .sv {
    color: var(--accent);
  }
  .sl {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-faint);
  }

  /* 区块通用 */
  .block {
    margin-bottom: 3.2rem;
  }
  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .sec-head .eyebrow {
    margin-bottom: 0;
  }
  .more {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-dim);
  }
  .more:hover {
    color: var(--accent);
  }
  .bio {
    margin-top: 1rem;
  }
  .bio p + p {
    margin-top: 1.1rem;
  }
  .bio em {
    font-family: var(--font-emphasis);
    font-style: normal;
  }

  /* 个人项目：编辑式索引行 → 多列网格（非圆角卡片） */
  .proj-list {
    margin-top: 0.9rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(1.5rem, 4vw, 3.5rem);
    border-top: 1px solid var(--line);
  }
  .proj {
    position: relative;
    display: block;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--line);
    transition: padding-left 0.45s var(--ease);
  }
  .proj::before {
    content: '';
    position: absolute;
    left: -1.1rem;
    top: 1.85rem;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--accent);
    transform: scale(0);
    transition: transform 0.4s var(--ease);
  }
  .proj:hover {
    padding-left: 1.3rem;
  }
  .proj:hover::before {
    transform: scale(1);
  }
  .proj-top {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .proj-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    letter-spacing: -0.01em;
    color: var(--fg);
    transition: color 0.2s;
  }
  .proj:hover .proj-name {
    color: var(--accent);
  }
  .proj-arrow {
    font-family: var(--font-mono);
    color: var(--fg-faint);
    transition: transform 0.35s var(--ease), color 0.2s;
  }
  .proj:hover .proj-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }
  .proj-desc {
    margin-top: 0.5rem;
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--fg-dim);
  }
  .proj-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.2rem;
    margin-top: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    color: var(--fg-faint);
  }
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    color: var(--fg-dim);
  }
  .lang-dot {
    width: 0.62em;
    height: 0.62em;
    border-radius: 50%;
    display: inline-block;
  }

  /* 喜欢的游戏：封面磁贴（灰度→悬停复色 + 取景框角标） */
  .game-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1.4rem 1.2rem;
    margin-top: 1.2rem;
  }
  .game {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .game-cover {
    position: relative;
    display: block;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    background: color-mix(in srgb, var(--fg) 6%, transparent);
  }
  .game-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.02);
    transition: filter 0.4s var(--ease), transform 0.5s var(--ease);
  }
  .game:hover .game-cover img {
    filter: none;
    transform: scale(1.04);
  }
  .game-ph {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 2.6rem;
    color: var(--fg-faint);
  }
  .gfc {
    position: absolute;
    width: 12px;
    height: 12px;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.25s var(--ease);
    pointer-events: none;
  }
  .gfc.tl { top: 7px; left: 7px; border-top: 1.5px solid var(--accent); border-left: 1.5px solid var(--accent); }
  .gfc.br { bottom: 7px; right: 7px; border-bottom: 1.5px solid var(--accent); border-right: 1.5px solid var(--accent); }
  .game:hover .gfc {
    opacity: 1;
  }
  .game-title {
    font-family: var(--font-zh-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--fg);
    transition: color 0.2s;
  }
  .game:hover .game-title {
    color: var(--accent);
  }
  .game-note {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.5;
    color: var(--fg-faint);
  }

  .contact {
    margin-bottom: 3rem;
  }
  .contact .eyebrow {
    margin-bottom: 1rem;
  }
  .back {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--fg-dim);
  }
  .back:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .proj-list {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 520px) {
    .game-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
