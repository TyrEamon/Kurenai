---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import ArticleToc from '../../components/ArticleToc.astro';
import ContentReveal from '../../components/ContentReveal.astro';
import CodeCopy from '../../components/CodeCopy.astro';
import LegacyEmbeds from '../../components/LegacyEmbeds.astro';
import {
  getPublishedPosts,
  coverTransitionName,
  formatMonthYear,
  readingTime,
  isRandomCover,
  type Post,
} from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post, i) => ({
    params: { id: post.id },
    props: {
      post,
      prev: posts[i + 1] ?? null,
      next: posts[i - 1] ?? null,
    },
  }));
}

interface Props {
  post: Post;
  prev: Post | null;
  next: Post | null;
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
const base = import.meta.env.BASE_URL;
const tname = coverTransitionName(post.id);
const mins = readingTime(post.body, post.data.lang);
const randomCover = isRandomCover(post.data.image);
---

<BaseLayout
  title={`${post.data.title} · RuneByte`}
  description={post.data.description}
  lang={post.data.lang}
  image={post.data.image}
>
  <ReadingProgress />

  <article class="article" data-pagefind-body>
    <header class="art-head wrap">
      {post.data.category && <p class="eyebrow">{post.data.category}</p>}
      <h1 class="art-title">{post.data.title}</h1>
      <div class="art-meta">
        <span>{formatMonthYear(post.data.published)}</span>
        <span>·</span>
        <span>{mins} 分钟</span>
        {
          post.data.tags.length > 0 && (
            <span class="art-tags">
              {post.data.tags.map((t) => (
                <span class="tag">#{t}</span>
              ))}
            </span>
          )
        }
      </div>

      <div hidden>
        <span data-pagefind-meta={`date:${post.data.published.toISOString()}`}></span>
        {post.data.image && <span data-pagefind-meta={`image:${post.data.image}`}></span>}
        <span data-pagefind-filter={`lang:${post.data.lang}`}></span>
        {post.data.category && <span data-pagefind-filter={`category:${post.data.category}`}></span>}
        {post.data.tags.map((t) => <span data-pagefind-filter={`tag:${t}`} />)}
      </div>
    </header>

    <div class="art-grid wrap">
      <div class="art-main">
        {
          post.data.image && (
            <div class="art-cover">
              <img
                src={post.data.image}
                alt=""
                transition:name={tname}
                data-random-cover={randomCover ? 'h' : undefined}
                data-random-key={randomCover ? post.id : undefined}
              />
            </div>
          )
        }

        <div class="prose">
          <Content />
        </div>
        <ContentReveal />
        <CodeCopy />
        <LegacyEmbeds />

        <nav class="art-nav" aria-label="上一篇 / 下一篇" data-pagefind-ignore>
          {
            prev ? (
              <a class="pn" href={`${base}blog/${prev.id}/`} data-cursor>
                <span class="pn-k">← 上一篇</span>
                <span class="pn-t">{prev.data.title}</span>
              </a>
            ) : (
              <span />
            )
          }
          {
            next && (
              <a class="pn pn-r" href={`${base}blog/${next.id}/`} data-cursor>
                <span class="pn-k">下一篇 →</span>
                <span class="pn-t">{next.data.title}</span>
              </a>
            )
          }
        </nav>
      </div>

      <aside class="art-aside" data-pagefind-ignore>
        <ArticleToc headings={headings} />
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding-top: clamp(2rem, 6vh, 4rem);
  }
  .art-head {
    margin-bottom: 2.5rem;
  }
  /* 头部级联淡入（仅非 reduced-motion；不含参与形变的封面） */
  @media (prefers-reduced-motion: no-preference) {
    .art-head .eyebrow {
      animation: head-up 0.55s var(--ease) both;
    }
    .art-head .art-title {
      animation: head-up 0.55s var(--ease) 0.08s both;
    }
    .art-head .art-meta {
      animation: head-up 0.55s var(--ease) 0.16s both;
    }
  }
  @keyframes head-up {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .art-title {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 5vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0.4rem 0 1rem;
    max-width: 20ch;
  }
  :global(:lang(zh)) .art-title {
    font-family: var(--font-zh-display);
    letter-spacing: 0;
    line-height: 1.25;
  }
  .art-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-faint);
    letter-spacing: 0.04em;
  }
  .art-tags {
    display: flex;
    gap: 0.5rem;
  }
  .tag {
    color: var(--fg-dim);
  }
  .art-cover {
    margin-top: 0; /* 封面置于左列顶部，与右侧目录列顶部对齐 */
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--line);
  }
  .art-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* 文章页两列：左 = 正文列（封面/标题/正文/上下篇都在此 → 封面与正文等宽）；右 = 目录列。
     整个 .art-grid 与 .wrap 同宽。两列都显式 grid-row:1。
     不要用 align-items:start —— 目录列需撑满整篇高度，内部 .toc 的 sticky 才有滑动空间。 */
  .art-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 232px;
    gap: clamp(2rem, 5vw, 4.5rem);
  }
  .art-main {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
  }
  .art-main .prose {
    max-width: none;
  }
  .art-aside {
    grid-column: 2;
    grid-row: 1;
  }
  .art-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .pn {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    max-width: 45%;
  }
  .pn-r {
    text-align: right;
    align-items: flex-end;
  }
  .pn-k {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--fg-faint);
  }
  .pn-t {
    color: var(--fg-dim);
    transition: color 0.2s;
  }
  .pn:hover .pn-t {
    color: var(--accent);
  }
  @media (max-width: 1080px) {
    .art-grid {
      grid-template-columns: minmax(0, 1fr);
    }
    .art-aside {
      display: none;
    }
  }
</style>
